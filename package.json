{
  "name": "@thinhpham/myai",
  "version": "0.6.1",
  "description": "Meta-prompting, context engineering, and spec-driven development for Claude Code, OpenCode, Gemini CLI, Codex, and Cursor",
  "type": "module",
  "bin": {
    "myai": "./bin/myai.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thinhphamp/myai.git"
  },
  "author": "Thinh Pham",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    ".myai/",
    "bin/",
    "lib/",
    "docs-templates/",
    "plans-templates/",
    "runtime-templates/",
    "scripts/postinstall.cjs",
    "!.myai/hooks/lib/.DS_Store",
    "!.myai/**/.DS_Store"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build:hooks": "node scripts/build-hooks.js",
    "prepublishOnly": "npm run build:hooks && node scripts/prepublish-check.cjs",
    "prepare": "husky install",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude-code",
    "ai-development",
    "meta-prompting",
    "context-engineering",
    "spec-driven",
    "skills",
    "agents"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "husky": "^8.0.0",
    "vitest": "^1.2.0"
  }
}
